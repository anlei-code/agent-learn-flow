APP_NAME=KnowledgeFlow Copilot
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
APP_API_PREFIX=/api/v1
APP_LOG_LEVEL=INFO

# LLM settings.
# LLM_PROVIDER can be auto, mock, or openai.
# auto means: use OpenAI when OPENAI_API_KEY is set, otherwise use local mock.
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
LLM_TIMEOUT_SECONDS=30
