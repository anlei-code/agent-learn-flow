APP_NAME=KnowledgeFlow Copilot
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
APP_API_PREFIX=/api/v1
APP_LOG_LEVEL=INFO

# LLM settings.
# LLM_PROVIDER can be auto, mock, or openai.
# auto means: use OpenAI when OPENAI_API_KEY is set, otherwise use local mock.
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_SYSTEM_PROMPT=你是 KnowledgeFlow Copilot 的学习助手。回答要简洁、准确，适合 Python 大模型应用开发初学者。
LLM_TIMEOUT_SECONDS=30
